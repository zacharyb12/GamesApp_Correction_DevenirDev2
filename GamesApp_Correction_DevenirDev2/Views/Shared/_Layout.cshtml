@using Microsoft.AspNetCore.Identity
@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>GamesApp</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/monStyle.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GamesApp_Correction_DevenirDev2.styles.css" asp-append-version="true" />
</head>
<body>

    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">

                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">GamesApp</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">

                        <li class="nav-item">
                            <a class="" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Game" asp-action="Index">Games</a>
                        </li>

                        @if(SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Game" asp-action="Create">Create Games</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Game" asp-action="MyGames">My Games</a>
                            </li>
                        }

                     </ul>

                     @if(SignInManager.IsSignedIn(User))
                        {
                            <ul class="navbar-nav">

                                <li class="nav-item">
                                    <a asp-controller="User" asp-action="Details" asp-route-id="@UserManager.GetUserId(User)">
                                        Bonjour , @User.Identity?.Name
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <form asp-controller="Auth" asp-action="Logout" >
                                        <button type="submit" class="nav-link btn btn-link text-dark">Deconnexion</button>
                                    </form>
                                </li>

                            </ul>
                        }
                        else
                        {
                            <ul class="navbar-nav">

                                <li class="nav-item">
                                    <a asp-controller="Auth" asp-action="Login" class="nav-item">Connexion</a>
                                </li>

                                <li class="nav-item">
                                    <a asp-controller="Auth" asp-action="Register" class="nav-item">S'enregistrer</a>
                                </li> 

                            </ul>
                        }
                    </div>
             </div>
        </nav>
    </header>


    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - GamesApp_Correction_DevenirDev2 - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
